{
  "name": "@vroskus/library-social",
  "version": "1.0.30",
  "description": "Social",
  "author": "Vilius Roškus <vilius@regattas.eu>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vroskus/library-social.git"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "npm run test:eslint && npm run test:type && npm run test:e2e",
    "test:eslint": "eslint src test --fix",
    "test:type": "tsc",
    "test:e2e": "npm run test:e2e:run && npm run test:e2e:post",
    "test:e2e:run": "jest --ci --colors",
    "test:e2e:post": "jest-coverage-thresholds-bumper"
  },
  "dependencies": {
    "@vroskus/library-validator": "^2.0.4",
    "axios": "^1.18.0",
    "axios-mock-adapter": "^2.1.0"
  },
  "devDependencies": {
    "@types/axios": "^0.14.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@vroskus/eslint-config": "^1.1.4",
    "express": "^5.2.1",
    "jest": "^30.4.2",
    "jest-coverage-thresholds-bumper": "^1.1.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "coverageReporters": [
      "json-summary",
      "text"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50.76,
        "functions": 76.19,
        "lines": 88.23,
        "statements": 76.25
      }
    }
  }
}
